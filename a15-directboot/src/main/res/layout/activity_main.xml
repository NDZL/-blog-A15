<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A15 Direct Boot Demo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- Device Status -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device Status"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#64FFDA"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:background="#16213E"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- DE Storage -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device Encrypted (DE) Storage — available BEFORE unlock"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFD54F"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDeStorage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:background="#16213E"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- CE Storage -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Credential Encrypted (CE) Storage — available AFTER unlock"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF8A65"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCeStorage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:background="#16213E"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStartService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start FGS"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnStopService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop FGS"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Status" />

    </LinearLayout>
</ScrollView>
