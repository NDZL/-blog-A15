<?xml version="1.0" encoding="utf-8"?>
<!--
  Blog (3): Enhancing User Experience & Multitasking — Text / i18n Features
  Demonstrates API 35 text rendering improvements:
    1. Inter-character justification
    2. LINE_BREAK_WORD_STYLE_AUTO
    3. elegantTextHeight (now true by default)
    4. CJK variable font support
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inter-Character Justification (API 35)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_inter_char_justify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This text demonstrates inter-character justification mode which distributes spacing between characters instead of only between words. Notice the letter spacing."
            android:textSize="16sp"
            android:layout_marginBottom="24dp"
            android:background="#F0F0F0"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LINE_BREAK_WORD_STYLE_AUTO (API 35)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_line_break_auto"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="This demonstrates automatic line break word style that applies phrase-based line breaking for short text."
            android:textSize="16sp"
            android:layout_marginBottom="24dp"
            android:background="#F0F0F0"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="elegantTextHeight (default true in API 35)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_elegant_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="สวัสดีครับ こんにちは 你好世界 مرحبا"
            android:textSize="24sp"
            android:layout_marginBottom="24dp"
            android:background="#F0F0F0"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CJK Variable Font (NotoSansCJK)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_cjk_variable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="漢字テスト 한국어 简体中文 繁體中文"
            android:textSize="24sp"
            android:layout_marginBottom="16dp"
            android:background="#F0F0F0"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
